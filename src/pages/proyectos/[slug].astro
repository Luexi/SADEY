---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import ProjectDetailHero from '../../components/sections/ProjectDetailHero.astro';
import EmptyGalleryState from '../../components/ui/EmptyGalleryState.astro';
import Gallery from '../../components/ui/Gallery.astro';
import Button from '../../components/ui/Button.astro';
import Container from '../../components/ui/Container.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import { projects } from '../../data/projects';
import { siteConfig } from '../../data/site';
import { withBase } from '../../utils/paths';
import type { ProjectCase } from '../../data/types';

export function getStaticPaths() {
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

interface Props {
	project: ProjectCase;
}

const { project } = Astro.props;
const pageTitle = `${project.title} | SADEY LABORATORIO`;
const pageDescription = project.metaDescription || project.summary;
const hasVideo = project.slug === 'adquisicion-mezcla-asfaltica';
const videoUrl = withBase('/assets/video/adquisicion-mezcla.mp4', siteConfig.basePath);
const posterUrl = withBase('/assets/video/adquisicion-mezcla-poster.jpg', siteConfig.basePath);
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalPath={`/proyectos/${project.slug}`}
>
	<ProjectDetailHero project={project} />

	<section class="project-detail section-shell">
		<Container>
			<div class="project-detail__grid">
				<div class="project-detail__main">
					<SectionHeading
						eyebrow="Descripción del proyecto"
						title={project.title}
					/>
					<p class="project-detail__description">{project.fullDescription}</p>

					<div class="project-detail__tags">
						{project.tags.map((tag) => (
							<span class="project-detail__tag">{tag}</span>
						))}
					</div>
				</div>

				<aside class="project-detail__sidebar">
					<div class="project-detail__meta">
						<div class="project-detail__meta-item">
							<span class="project-detail__meta-label">Categoría</span>
							<span class="project-detail__meta-value">{project.category}</span>
						</div>
						{project.contractNumber && (
							<div class="project-detail__meta-item">
								<span class="project-detail__meta-label">Contrato</span>
								<span class="project-detail__meta-value">{project.contractNumber}</span>
							</div>
						)}
					</div>

					<div class="project-detail__actions">
						<Button href={siteConfig.whatsappUrl} label="Consultar sobre este proyecto" fullWidth target="_blank" rel="noopener noreferrer" />
						<Button href="/proyectos" label="← Volver a proyectos" variant="ghost" fullWidth />
					</div>
				</aside>
			</div>
		</Container>
	</section>

	{project.comparison && (
		<section class="project-comparison section-shell">
			<Container>
				<SectionHeading
					eyebrow="Antes y despues"
					title={project.comparison.title}
				/>
				<p class="project-comparison__description">
					{project.comparison.description}
				</p>

				<div class="project-comparison__grid">
					<figure class="project-comparison__figure">
						<Image
							src={project.comparison.before.src}
							alt={project.comparison.before.alt}
							widths={[480, 720, 960]}
							sizes="(min-width: 760px) 50vw, 100vw"
							loading="lazy"
							decoding="async"
						/>
						<figcaption>
							<strong>{project.comparison.before.caption || 'Antes'}</strong>
							<span>{project.comparison.before.alt}</span>
						</figcaption>
					</figure>

					<figure class="project-comparison__figure">
						<Image
							src={project.comparison.after.src}
							alt={project.comparison.after.alt}
							widths={[480, 720, 960]}
							sizes="(min-width: 760px) 50vw, 100vw"
							loading="lazy"
							decoding="async"
						/>
						<figcaption>
							<strong>{project.comparison.after.caption || 'Despues'}</strong>
							<span>{project.comparison.after.alt}</span>
						</figcaption>
					</figure>
				</div>
			</Container>
		</section>
	)}

	{hasVideo && (
		<section class="project-video section-shell">
			<Container>
				<SectionHeading
					eyebrow="Registro en obra"
					title="Video del proceso"
				/>
				<video
					class="project-video__player"
					controls
					preload="metadata"
					poster={posterUrl}
					playsinline
				>
					<source src={videoUrl} type="video/mp4" />
					Tu navegador no soporta la reproducción de video HTML5.
				</video>
			</Container>
		</section>
	)}

	<section class="project-gallery section-shell">
		<Container>
			<SectionHeading
				eyebrow="Galería del proyecto"
				title="Registro visual"
			/>
			{project.gallery.length > 0 ? (
				<Gallery images={project.gallery} groupId={project.slug} />
			) : (
				<div class="project-gallery__empty">
					<EmptyGalleryState />
				</div>
			)}
		</Container>
	</section>
</BaseLayout>

<style>
	.project-detail {
		background: var(--color-surface);
	}

	.project-detail__grid {
		display: grid;
		grid-template-columns: 1fr minmax(260px, 0.4fr);
		gap: var(--space-xl);
		align-items: start;
	}

	.project-detail__main {
		display: grid;
		gap: 1.25rem;
	}

	.project-detail__description {
		margin: 0;
		font-size: 1.02rem;
		line-height: 1.7;
		color: var(--color-on-surface-variant);
	}

	.project-detail__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.project-detail__tag {
		padding: 0.4rem 0.7rem;
		border-radius: 999px;
		background: var(--color-surface-alt);
		font-size: 0.78rem;
		font-weight: 600;
		color: var(--color-on-surface-variant);
	}

	.project-detail__sidebar {
		display: grid;
		gap: 1.5rem;
	}

	.project-detail__meta {
		display: grid;
		gap: 1rem;
		padding: 1.5rem;
		background: var(--color-surface-strong);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-soft);
	}

	.project-detail__meta-item {
		display: grid;
		gap: 0.25rem;
	}

	.project-detail__meta-label {
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-secondary);
	}

	.project-detail__meta-value {
		font-size: 0.95rem;
		color: var(--color-on-surface);
	}

	.project-detail__actions {
		display: grid;
		gap: 0.7rem;
	}

	.project-video {
		background: var(--color-surface);
	}

	.project-comparison {
		background: var(--color-bg);
	}

	.project-comparison__description {
		max-width: 720px;
		margin: 0.75rem 0 0;
		color: var(--color-on-surface-variant);
		line-height: 1.65;
	}

	.project-comparison__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		margin-top: var(--space-lg);
	}

	.project-comparison__figure {
		display: grid;
		gap: 0.8rem;
		margin: 0;
		padding: 0.7rem;
		background: var(--color-surface-strong);
		border: 1px solid rgba(181, 135, 63, 0.22);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-soft);
	}

	.project-comparison__figure :global(img) {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		border-radius: var(--radius-md);
	}

	.project-comparison__figure figcaption {
		display: grid;
		gap: 0.25rem;
		padding: 0 0.25rem 0.25rem;
	}

	.project-comparison__figure strong {
		color: var(--color-secondary);
		font-family: var(--font-heading);
		font-size: 0.82rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
	}

	.project-comparison__figure span {
		color: var(--color-on-surface-variant);
		font-size: 0.92rem;
		line-height: 1.5;
	}

	.project-video__player {
		display: block;
		width: 100%;
		max-width: 960px;
		margin: var(--space-lg) auto 0;
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-soft);
		background: #000;
	}

	.project-gallery {
		background: var(--color-bg);
	}

	.project-gallery__empty {
		margin-top: var(--space-lg);
	}

	@media (max-width: 860px) {
		.project-detail__grid {
			grid-template-columns: 1fr;
		}
	}

	@media (min-width: 760px) {
		.project-comparison__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>
