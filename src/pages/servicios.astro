---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import ServiceCategoryBlock from '../components/sections/ServiceCategoryBlock.astro';
import CTAWhatsApp from '../components/sections/CTAWhatsApp.astro';
import Container from '../components/ui/Container.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import { services } from '../data/services';
import { differentiators } from '../data/differentiators';
import { siteConfig } from '../data/site';
---

<BaseLayout
	title={siteConfig.pageMeta.servicios.title}
	description={siteConfig.pageMeta.servicios.description}
	canonicalPath="/servicios"
>
	<PageHero
		eyebrow="Servicios"
		title="Pruebas específicas por categoría"
		description="En SADEY LABORATORIO ejecutamos pruebas específicas para concretos, agregados pétreos, mezcla asfáltica, terracerías y SIAC, tanto en laboratorio como directamente en obra."
	/>

	<section class="services-list section-shell">
		<Container>
			<div class="services-list__grid">
				{services.map((service) => (
					<ServiceCategoryBlock service={service} />
				))}
			</div>
		</Container>
	</section>

	<section class="why section-shell">
		<Container>
			<SectionHeading
				eyebrow="¿Por qué SADEY LABORATORIO?"
				title="Razones claras para trabajar con nosotros"
				align="center"
			/>

			<div class="why__grid">
				{differentiators.map((item) => (
					<article class="why__card">
						<span class="why__icon">{item.icon}</span>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</article>
				))}
			</div>
		</Container>
	</section>

	<CTAWhatsApp />
</BaseLayout>

<style>
	.services-list {
		background: var(--color-surface);
	}

	.services-list__grid {
		display: grid;
		gap: 1.5rem;
	}

	/* Why section — relocated from WhySadey component */
	.why {
		background: var(--color-bg);
	}

	.why__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
		margin-top: var(--space-xl);
	}

	.why__card {
		display: grid;
		gap: 0.8rem;
		padding: 1.5rem;
		background: var(--color-surface-strong);
		border: 1px solid transparent;
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-sm);
		transition:
			transform var(--transition-base),
			box-shadow var(--transition-base),
			border-color var(--transition-base);
	}

	.why__card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-card-hover);
		border-color: rgba(181, 135, 63, 0.28);
	}

	.why__card:hover .why__icon {
		background: var(--color-accent-gradient);
		color: var(--color-on-primary);
	}

	.why__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.9rem;
		height: 2.9rem;
		border-radius: 999px;
		background: var(--color-secondary-soft);
		font-family: var(--font-display);
		font-weight: 700;
		color: var(--color-secondary);
		transition:
			background var(--transition-base),
			color var(--transition-base);
	}

	.why__card h3,
	.why__card p {
		margin: 0;
	}

	.why__card h3 {
		font-family: var(--font-display);
		font-size: 1.15rem;
		line-height: 1.08;
		color: var(--color-primary);
	}

	.why__card p {
		color: var(--color-on-surface-variant);
	}

	@media (max-width: 980px) {
		.why__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.why__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
