---
import Container from '../ui/Container.astro';
import { siteConfig } from '../../data/site';
import { withBase } from '../../utils/paths';

const { contact } = siteConfig;
---

<footer class="site-footer">
	<Container>
		<div class="site-footer__inner">
			<div class="site-footer__brand">
				<p class="site-footer__logo">{siteConfig.logoText}</p>
				<p class="site-footer__note">{siteConfig.footerNote}</p>
			</div>

			<div class="site-footer__column">
				<h2>Navegación</h2>
				<ul>
					{
						siteConfig.navigation.map((item) => (
							<li>
								<a href={item.kind === 'external' ? item.href : withBase(item.href, siteConfig.basePath)}>
									{item.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<div class="site-footer__column">
				<h2>Contacto</h2>
				<ul>
					<li>
						<a href={`tel:${contact.phone}`}>{contact.phoneDisplay}</a>
					</li>
					{contact.email && (
						<li>
							<a href={`mailto:${contact.email}`}>{contact.email}</a>
						</li>
					)}
					<li>{contact.address}</li>
					<li>
						<a href={contact.whatsappUrl} target="_blank" rel="noopener noreferrer">WhatsApp</a>
					</li>
				</ul>
			</div>
		</div>
	</Container>

	<Container>
		<div class="site-footer__bottom">
			<p>© {new Date().getFullYear()} MTHA SADEY. Laboratorio para la construcción.</p>
		</div>
	</Container>
</footer>

<style>
	.site-footer {
		padding: var(--space-2xl) 0 var(--space-lg);
		background:
			linear-gradient(180deg, rgba(8, 17, 35, 0.98), rgba(8, 17, 35, 1)),
			var(--color-primary-deep);
		color: var(--color-on-primary);
	}

	.site-footer__inner {
		display: grid;
		grid-template-columns: 1.3fr 0.75fr 0.9fr;
		gap: var(--space-lg);
	}

	.site-footer__logo,
	.site-footer__column h2 {
		margin: 0 0 1rem;
		font-family: var(--font-display);
		font-size: 1.28rem;
		line-height: 1.1;
	}

	.site-footer__note,
	.site-footer__column li,
	.site-footer__column a,
	.site-footer__bottom p {
		color: var(--color-muted-inverse);
	}

	.site-footer__note {
		max-width: 30rem;
		margin: 0;
	}

	.site-footer__column ul {
		display: grid;
		gap: 0.75rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.site-footer__column a:hover {
		color: var(--color-secondary-strong);
	}

	.site-footer__bottom {
		padding-top: var(--space-lg);
		margin-top: var(--space-lg);
		border-top: 1px solid rgba(255, 255, 255, 0.12);
	}

	.site-footer__bottom p {
		margin: 0;
		font-size: 0.88rem;
	}

	@media (max-width: 860px) {
		.site-footer__inner {
			grid-template-columns: 1fr;
		}
	}
</style>
