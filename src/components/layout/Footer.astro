---
import Container from '../ui/Container.astro';
import { siteConfig } from '../../data/site';
import { withBase } from '../../utils/paths';

const { contact } = siteConfig;
---

<footer class="site-footer">
	<Container>
		<div class="site-footer__inner">
			<div class="site-footer__brand">
				<p class="site-footer__logo">{siteConfig.logoText}</p>
				<p class="site-footer__note">{siteConfig.footerNote}</p>
			</div>

			<div class="site-footer__column site-footer__column--nav">
				<h2>Navegacion</h2>
				<ul class="site-footer__nav-list">
					{
						siteConfig.navigation.map((item) => (
							<li>
								<a href={item.kind === 'external' ? item.href : withBase(item.href, siteConfig.basePath)}>
									{item.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<div class="site-footer__column site-footer__column--contact">
				<h2>Contacto</h2>
				<ul class="site-footer__contact-list">
					<li>
						<span class="site-footer__label">Tel</span>
						<a href={`tel:${contact.phone}`}>{contact.phoneDisplay}</a>
					</li>
					{contact.email && (
						<li>
							<span class="site-footer__label">Email</span>
							<a href={`mailto:${contact.email}`}>{contact.email}</a>
						</li>
					)}
					<li>
						<span class="site-footer__label">Direccion</span>
						<span>{contact.address}</span>
					</li>
					<li>
						<span class="site-footer__label">WhatsApp</span>
						<a href={contact.whatsappUrl} target="_blank" rel="noopener noreferrer">Abrir chat</a>
					</li>
				</ul>
			</div>
		</div>
	</Container>

	<Container>
		<div class="site-footer__bottom">
			<p>© {new Date().getFullYear()} SADEY LABORATORIO PARA LA CONSTRUCCION.</p>
		</div>
	</Container>
</footer>

<style>
	.site-footer {
		padding: var(--space-xl) 0 var(--space-md);
		background:
			linear-gradient(180deg, rgba(8, 17, 35, 0.98), rgba(8, 17, 35, 1)),
			var(--color-primary-deep);
		color: var(--color-on-primary);
	}

	.site-footer__inner {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.82fr) minmax(0, 1fr);
		gap: var(--space-md);
		align-items: start;
	}

	.site-footer__logo,
	.site-footer__column h2 {
		margin: 0 0 0.7rem;
		font-family: var(--font-display);
		font-size: 1.02rem;
		line-height: 1.1;
	}

	.site-footer__note,
	.site-footer__column li,
	.site-footer__column a,
	.site-footer__bottom p,
	.site-footer__contact-list span:last-child {
		color: var(--color-muted-inverse);
	}

	.site-footer__brand,
	.site-footer__column {
		display: grid;
		gap: 0.45rem;
	}

	.site-footer__note {
		max-width: 28rem;
		margin: 0;
		font-size: 0.94rem;
		line-height: 1.5;
	}

	.site-footer__column ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.site-footer__nav-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
	}

	.site-footer__nav-list li {
		display: flex;
	}

	.site-footer__nav-list a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.48rem 0.82rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid rgba(255, 255, 255, 0.08);
		font-size: 0.9rem;
	}

	.site-footer__contact-list {
		display: grid;
		gap: 0.6rem;
	}

	.site-footer__contact-list li {
		display: grid;
		gap: 0.14rem;
	}

	.site-footer__label {
		font-size: 0.66rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(214, 174, 104, 0.82);
	}

	.site-footer__column a:hover {
		color: var(--color-secondary-strong);
	}

	.site-footer__bottom {
		padding-top: var(--space-md);
		margin-top: var(--space-md);
		border-top: 1px solid rgba(255, 255, 255, 0.12);
	}

	.site-footer__bottom p {
		margin: 0;
		font-size: 0.84rem;
	}

	@media (max-width: 860px) {
		.site-footer {
			padding: var(--space-lg) 0 var(--space-sm);
		}

		.site-footer__inner {
			grid-template-columns: 1fr;
			gap: 1.15rem;
		}

		.site-footer__note {
			max-width: none;
		}

		.site-footer__nav-list a {
			padding: 0.44rem 0.72rem;
			font-size: 0.86rem;
		}

		.site-footer__contact-list {
			gap: 0.5rem;
		}

		.site-footer__bottom {
			padding-top: var(--space-sm);
			margin-top: var(--space-sm);
		}
	}
</style>
