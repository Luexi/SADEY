---
import Button from '../ui/Button.astro';
import Container from '../ui/Container.astro';
import { siteConfig } from '../../data/site';
import { withBase } from '../../utils/paths';
---

<header class="site-header">
	<Container>
		<div class="site-header__inner">
			<!-- Logo slot: replace the text below with an <img> when the final logo is ready.
			     Expected location: public/assets/branding/logo.svg or logo.png
			     Replace: <span class="site-header__logo">{siteConfig.logoText}</span>
			     With:    <img src={withBase('/assets/branding/logo.svg', siteConfig.basePath)} alt="MTHA SADEY" class="site-header__logo-img" />
			-->
			<a class="site-header__brand" href={withBase('/', siteConfig.basePath)} aria-label="Ir al inicio de MTHA SADEY">
				<span class="site-header__logo">{siteConfig.logoText}</span>
				<span class="site-header__tag">Laboratorio para la construcción</span>
			</a>

			<nav class="site-header__nav" aria-label="Navegación principal">
				<ul>
					{
						siteConfig.navigation.map((item) => (
							<li>
								<a href={item.kind === 'external' ? item.href : withBase(item.href, siteConfig.basePath)}>
									{item.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<div class="site-header__cta">
				<Button
					href={siteConfig.headerCta.href}
					label={siteConfig.headerCta.label}
					target="_blank"
					rel="noopener noreferrer"
				/>
			</div>
		</div>
	</Container>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 40;
		padding: 1rem 0;
		background: rgba(8, 17, 35, 0.9);
		backdrop-filter: blur(20px);
		box-shadow: 0 18px 38px rgba(8, 17, 35, 0.16);
	}

	.site-header__inner {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1.5rem;
	}

	.site-header__brand {
		display: grid;
		gap: 0.12rem;
	}

	.site-header__logo {
		font-family: var(--font-display);
		font-size: 1.42rem;
		font-weight: 800;
		letter-spacing: -0.04em;
		color: var(--color-on-primary);
	}

	.site-header__tag {
		font-size: 0.78rem;
		color: rgba(255, 255, 255, 0.68);
	}

	.site-header__nav {
		justify-self: center;
	}

	.site-header__nav ul {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 1.4rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.site-header__nav a {
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.76);
		transition: color var(--transition-base);
	}

	.site-header__nav a:hover {
		color: var(--color-secondary-strong);
	}

	@media (max-width: 920px) {
		.site-header__inner {
			grid-template-columns: 1fr auto;
		}

		.site-header__nav {
			grid-column: 1 / -1;
			justify-self: stretch;
		}

		.site-header__nav ul {
			justify-content: flex-start;
			row-gap: 0.8rem;
		}
	}

	@media (max-width: 640px) {
		.site-header__inner {
			grid-template-columns: 1fr;
		}

		.site-header__cta {
			width: 100%;
		}

		.site-header__cta :global(.button) {
			width: 100%;
		}
	}
</style>
