---
import { Image } from 'astro:assets';
import Container from '../ui/Container.astro';
import { siteConfig } from '../../data/site';
import { withBase } from '../../utils/paths';
import logo from '../../assets/branding/logo.png';

const currentPath = (() => {
	const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
	const normalizedBase = siteConfig.basePath === '/' ? '' : siteConfig.basePath.replace(/\/$/, '');

	if (!normalizedBase || !pathname.startsWith(normalizedBase)) {
		return pathname;
	}

	const withoutBase = pathname.slice(normalizedBase.length) || '/';
	return withoutBase.startsWith('/') ? withoutBase : `/${withoutBase}`;
})();

const isActiveNavItem = (href: string) => {
	if (href === '/') {
		return currentPath === '/';
	}

	return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<header class="site-header">
	<Container>
		<div class="site-header__inner">
			<a class="site-header__brand" href={withBase('/', siteConfig.basePath)} aria-label={`Ir al inicio de ${siteConfig.logoText}`}>
				<Image
					src={logo}
					alt={siteConfig.logoText}
					class="site-header__logo-img"
					widths={[240, 480, 640]}
					sizes="(max-width: 640px) 150px, 220px"
					loading="eager"
				/>
				<span class="site-header__brand-text">
					<span class="site-header__wordmark">{siteConfig.brandName}</span>
					<span class="site-header__tagline">{siteConfig.brandTagline}</span>
				</span>
			</a>

			<nav class="site-header__nav" aria-label="Navegación principal">
				<ul>
					{
						siteConfig.navigation.map((item) => (
							<li>
								<a
									href={item.kind === 'external' ? item.href : withBase(item.href, siteConfig.basePath)}
									class:list={{ 'site-header__nav-link--active': item.kind === 'route' && isActiveNavItem(item.href) }}
									aria-current={item.kind === 'route' && isActiveNavItem(item.href) ? 'page' : undefined}
								>
									{item.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>
		</div>
	</Container>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 40;
		padding: 1rem 0 0.85rem;
		background: rgba(8, 17, 35, 0.9);
		backdrop-filter: blur(20px);
		box-shadow: 0 18px 38px rgba(8, 17, 35, 0.16);
	}

	.site-header__inner {
		display: grid;
		gap: 0.95rem;
	}

	.site-header__brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		width: max-content;
		text-decoration: none;
	}

	.site-header__logo-img {
		display: block;
		height: clamp(3rem, 5vw, 4rem);
		width: auto;
		object-fit: contain;
		flex-shrink: 0;
	}

	.site-header__brand-text {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.22rem;
		min-height: clamp(3rem, 5vw, 4rem);
		line-height: 1;
		padding-top: 0.08rem;
	}

	.site-header__wordmark {
		font-family: var(--font-display);
		font-size: clamp(1.3rem, 2.1vw, 1.75rem);
		font-weight: 800;
		letter-spacing: 0.08em;
		line-height: 1;
		color: #ffffff;
	}

	.site-header__tagline {
		font-family: var(--font-display);
		font-size: clamp(0.6rem, 0.9vw, 0.72rem);
		font-weight: 600;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.9);
		white-space: nowrap;
	}

	.site-header__nav ul {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: flex-start;
		gap: 0.85rem 1.35rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.site-header__nav a {
		display: inline-flex;
		padding: 0.38rem 0.72rem;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		border: 1px solid transparent;
		border-radius: 999px;
		color: rgba(255, 255, 255, 0.76);
		transition:
			color var(--transition-base),
			border-color var(--transition-base),
			background-color var(--transition-base),
			box-shadow var(--transition-base);
	}

	.site-header__nav a:hover {
		color: var(--color-secondary-strong);
	}

	.site-header__nav a.site-header__nav-link--active {
		color: var(--color-secondary-strong);
		border-color: rgba(214, 174, 104, 0.72);
		background: rgba(214, 174, 104, 0.08);
		box-shadow: inset 0 0 0 1px rgba(214, 174, 104, 0.14);
	}

	@media (max-width: 640px) {
		.site-header__tagline {
			font-size: 0.58rem;
			letter-spacing: 0.14em;
			white-space: normal;
		}
	}

	@media (max-width: 480px) {
		.site-header {
			padding: 0.9rem 0 0.75rem;
		}

		.site-header__brand {
			align-items: center;
			gap: 0.65rem;
		}

		.site-header__nav ul {
			gap: 0.75rem 1rem;
		}
	}
</style>
