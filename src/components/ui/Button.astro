---
import { siteConfig } from '../../data/site';
import { withBase } from '../../utils/paths';

interface Props {
	href?: string;
	label: string;
	variant?: 'primary' | 'secondary' | 'ghost';
	fullWidth?: boolean;
	disabled?: boolean;
	target?: string;
	rel?: string;
}

const {
	href,
	label,
	variant = 'primary',
	fullWidth = false,
	disabled = false,
	target,
	rel,
} = Astro.props;

const resolvedHref = href ? withBase(href, siteConfig.basePath) : undefined;
const className = ['button', `button--${variant}`, fullWidth && 'button--full', disabled && 'button--disabled'];
---

{
	disabled || !resolvedHref ? (
		<span class:list={className} aria-disabled="true">
			{label}
		</span>
	) : (
		<a class:list={className} href={resolvedHref} target={target} rel={rel}>
			{label}
		</a>
	)
}

<style>
	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 3.15rem;
		padding: 0.9rem 1.45rem;
		border-radius: var(--radius-md);
		border: 1px solid transparent;
		font-family: var(--font-body);
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		transition:
			transform var(--transition-base),
			background-color var(--transition-base),
			color var(--transition-base),
			border-color var(--transition-base),
			box-shadow var(--transition-base);
	}

	.button:hover {
		transform: translateY(-1px);
	}

	.button:active {
		transform: translateY(1px) scale(0.99);
		transition-duration: 80ms;
	}

	.button--primary {
		background: var(--color-accent-gradient);
		color: var(--color-on-primary);
		box-shadow: var(--shadow-button);
	}

	.button--primary:hover {
		box-shadow: var(--shadow-gold-glow);
	}

	.button--secondary {
		background: rgba(255, 255, 255, 0.84);
		border-color: rgba(11, 23, 48, 0.12);
		color: var(--color-primary);
	}

	.button--secondary:hover {
		background: var(--color-surface-strong);
	}

	.button--ghost {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.2);
		color: var(--color-on-primary);
		backdrop-filter: blur(10px);
	}

	.button--ghost:hover {
		background: rgba(255, 255, 255, 0.14);
	}

	.button--full {
		width: 100%;
	}

	.button--disabled {
		opacity: 0.6;
		cursor: default;
	}

	.button--disabled:hover {
		transform: none;
		box-shadow: none;
	}
</style>
