---
interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
	align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<div class:list={['section-heading', `section-heading--${align}`, 'section-intro']}>
	{eyebrow && (
		<div class="section-heading__eyebrow-row">
			<span class="eyebrow">{eyebrow}</span>
		</div>
	)}
	<h2>{title}</h2>
	{description && <p>{description}</p>}
</div>

<style>
	.section-heading {
		display: grid;
		gap: 0.9rem;
	}

	.section-heading h2 {
		margin: 0;
		font-family: var(--font-display);
		font-size: var(--text-h2);
		font-weight: 800;
		line-height: 1.04;
		letter-spacing: var(--tracking-tight);
		color: var(--color-primary);
		text-wrap: balance;
	}

	.section-heading p {
		color: var(--color-on-surface-variant);
		max-width: 42rem;
		text-wrap: pretty;
	}

	.section-heading--center p {
		margin-inline: auto;
	}

	.section-heading__eyebrow-row {
		display: flex;
		align-items: center;
	}

	.section-heading--center {
		margin-inline: auto;
		text-align: center;
	}

	.section-heading--center .section-heading__eyebrow-row {
		justify-content: center;
		gap: 1rem;
	}

	.section-heading--center .section-heading__eyebrow-row::before,
	.section-heading--center .section-heading__eyebrow-row::after {
		content: '';
		width: clamp(3rem, 8vw, 6rem);
		height: 1px;
		background: rgba(181, 135, 63, 0.4);
	}
</style>
