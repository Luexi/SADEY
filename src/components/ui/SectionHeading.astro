---
interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
	align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<div class:list={['section-heading', `section-heading--${align}`, 'section-intro']}>
	{eyebrow && <span class="eyebrow">{eyebrow}</span>}
	<h2>{title}</h2>
	{description && <p>{description}</p>}
</div>

<style>
	.section-heading {
		display: grid;
		gap: var(--space-sm);
	}

	.section-heading h2 {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(2rem, 4vw, 3.35rem);
		line-height: 1.05;
		letter-spacing: -0.03em;
	}

	.section-heading--center {
		margin-inline: auto;
		text-align: center;
	}
</style>
