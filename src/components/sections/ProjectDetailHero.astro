---
import { Image } from 'astro:assets';
import Container from '../ui/Container.astro';
import type { ProjectCase } from '../../data/types';

interface Props {
	project: ProjectCase;
}

const { project } = Astro.props;
---

<section class="project-hero">
	<Container>
		<div class="project-hero__panel">
			<div class="project-hero__media">
				<Image
					src={project.image.src}
					alt={project.image.alt}
					widths={[960, 1600]}
					sizes="100vw"
					loading="eager"
					fetchpriority="high"
				/>
			</div>
			<div class="project-hero__overlay"></div>
			<div class="project-hero__content">
				<p class="project-hero__category">{project.category}</p>
				<h1>{project.title}</h1>
				{project.contractNumber && (
					<p class="project-hero__contract">Contrato: {project.contractNumber}</p>
				)}
			</div>
		</div>
	</Container>
</section>

<style>
	.project-hero {
		padding: 1.15rem 0 var(--space-lg);
	}

	.project-hero__panel {
		position: relative;
		min-height: clamp(18rem, 40vh, 26rem);
		overflow: hidden;
		border-radius: var(--radius-xl);
		background: var(--color-primary);
		box-shadow: var(--shadow-card);
		isolation: isolate;
	}

	.project-hero__media,
	.project-hero__overlay {
		position: absolute;
		inset: 0;
	}

	.project-hero__media :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.project-hero__overlay {
		background:
			linear-gradient(90deg, rgba(8, 17, 35, 0.88) 0%, rgba(8, 17, 35, 0.7) 42%, rgba(8, 17, 35, 0.3) 100%),
			linear-gradient(180deg, rgba(8, 17, 35, 0.2) 0%, rgba(8, 17, 35, 0.7) 100%);
	}

	.project-hero__content {
		position: relative;
		z-index: 1;
		display: grid;
		gap: 0.8rem;
		max-width: 36rem;
		padding: clamp(2rem, 5vw, 3.5rem);
		color: var(--color-on-primary);
	}

	.project-hero__category {
		margin: 0;
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-secondary-strong);
	}

	h1 {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(1.8rem, 3.8vw, 3rem);
		line-height: 1.04;
		letter-spacing: -0.03em;
	}

	.project-hero__contract {
		margin: 0;
		font-size: 0.84rem;
		color: rgba(255, 255, 255, 0.7);
	}

	@media (max-width: 720px) {
		.project-hero__panel {
			min-height: auto;
		}

		.project-hero__overlay {
			background:
				linear-gradient(180deg, rgba(8, 17, 35, 0.78) 0%, rgba(8, 17, 35, 0.9) 100%);
		}

		.project-hero__content {
			max-width: none;
			padding: 2rem 1.4rem;
		}
	}
</style>
