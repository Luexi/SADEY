---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { siteConfig } from '../../data/site';
import { withBase } from '../../utils/paths';
---

<section class="about section-shell" id="sobre-nosotros">
	<Container className="about__grid">
		<div class="about__copy surface-panel">
			<SectionHeading eyebrow="Quiénes somos" title={siteConfig.about.title} />
			<div class="about__paragraphs">
				{siteConfig.about.description.map((paragraph) => <p>{paragraph}</p>)}
			</div>
		</div>

		<div class="about__image surface-panel">
			<img src={withBase(siteConfig.about.image.src, siteConfig.basePath)} alt={siteConfig.about.image.alt} loading="lazy" />
		</div>
	</Container>
</section>

<style>
	.about__grid {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
		gap: var(--space-lg);
		align-items: stretch;
	}

	.about__copy,
	.about__image {
		padding: var(--space-lg);
		border-radius: var(--radius-lg);
	}

	.about__paragraphs {
		display: grid;
		gap: var(--space-sm);
		margin-top: var(--space-md);
	}

	.about__paragraphs p {
		margin: 0;
		color: var(--color-text-muted);
	}

	.about__image img {
		width: 100%;
		height: 100%;
		border-radius: calc(var(--radius-md) - 0.25rem);
		object-fit: cover;
	}

	@media (max-width: 900px) {
		.about__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
