---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { projects } from '../../data/projects';
import { siteConfig } from '../../data/site';
import { withBase } from '../../utils/paths';
---

<section class="projects section-shell" id="proyectos">
	<Container>
		<div class="projects__header">
			<SectionHeading
				eyebrow="Proyectos recientes"
				title="Experiencia técnica respaldada por resultados en campo"
				description="Proyectos reales donde SADEY LABORATORIO ha brindado pruebas específicas, control de calidad y apoyo técnico."
			/>
		</div>

		<div class="projects__grid">
			{
				projects.map((project) => (
					<a class="projects__card" href={withBase(`/proyectos/${project.slug}`, siteConfig.basePath)}>
						<div class="projects__image-wrap">
							<Image
								src={project.image.src}
								alt={project.image.alt}
								widths={[480, 960]}
								sizes="(max-width: 980px) 100vw, 33vw"
								loading="lazy"
							/>
						</div>
						<div class="projects__body">
							<p class="projects__category">{project.category}</p>
							<h3>{project.title}</h3>
							<p class="projects__summary">{project.summary}</p>
							<span class="projects__link-hint">Ver proyecto →</span>
						</div>
					</a>
				))
			}
		</div>

		<div class="projects__actions">
			<Button href="/proyectos" label="Ver todos los proyectos" variant="ghost" />
		</div>
	</Container>
</section>

<style>
	.projects {
		background:
			linear-gradient(180deg, rgba(8, 17, 35, 0.98), rgba(11, 23, 48, 1)),
			var(--color-primary-deep);
		color: var(--color-on-primary);
	}

	.projects__header :global(.section-heading h2) {
		color: var(--color-on-primary);
	}

	.projects__header :global(.section-intro p) {
		color: rgba(255, 255, 255, 0.72);
	}

	.projects__header :global(.eyebrow) {
		color: var(--color-secondary-strong);
	}

	.projects__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.2rem;
		margin-top: var(--space-xl);
	}

	.projects__card {
		display: block;
		overflow: hidden;
		border-radius: var(--radius-lg);
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid rgba(255, 255, 255, 0.08);
		box-shadow: var(--shadow-card);
		transition: transform var(--transition-base), box-shadow var(--transition-base);
	}

	.projects__card:hover {
		transform: translateY(-3px);
		box-shadow: 0 32px 72px rgba(11, 23, 48, 0.22);
	}

	.projects__image-wrap {
		position: relative;
		overflow: hidden;
	}

	.projects__image-wrap::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, transparent 0%, rgba(8, 17, 35, 0.24) 100%);
	}

	.projects__image-wrap :global(img) {
		width: 100%;
		aspect-ratio: 16 / 10;
		object-fit: cover;
	}

	.projects__body {
		display: grid;
		gap: 0.7rem;
		padding: 1.35rem;
	}

	.projects__category {
		margin: 0;
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-secondary-strong);
	}

	h3,
	.projects__summary {
		margin: 0;
	}

	h3 {
		font-family: var(--font-display);
		font-size: 1.28rem;
		line-height: 1.08;
		color: var(--color-on-primary);
	}

	.projects__summary {
		color: rgba(255, 255, 255, 0.74);
	}

	.projects__link-hint {
		font-size: 0.82rem;
		font-weight: 700;
		color: var(--color-secondary-strong);
		letter-spacing: 0.04em;
	}

	.projects__actions {
		display: flex;
		justify-content: center;
		margin-top: var(--space-lg);
	}

	@media (max-width: 980px) {
		.projects__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
