---
import Button from '../ui/Button.astro';
import Container from '../ui/Container.astro';
import { siteConfig } from '../../data/site';
---

<section class="cta section-shell">
	<Container>
		<div class="cta__panel">
			<div class="cta__copy">
				<span class="eyebrow">Canal de contacto</span>
				<h2>{siteConfig.cta.title}</h2>
				<p>{siteConfig.cta.description}</p>
				<p class="cta__note">{siteConfig.cta.note}</p>
			</div>

			<div class="cta__actions">
				<Button href={siteConfig.whatsappUrl} label={siteConfig.cta.primaryLabel} fullWidth target="_blank" rel="noopener noreferrer" />
				<Button href="/contacto" label={siteConfig.cta.secondaryLabel} variant="ghost" fullWidth />
			</div>
		</div>
	</Container>
</section>

<style>
	.cta {
		padding-top: var(--space-2xl);
	}

	.cta__panel {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.8fr);
		gap: var(--space-lg);
		padding: clamp(1.7rem, 4vw, 2.7rem);
		border-radius: var(--radius-xl);
		background:
			radial-gradient(circle at 85% 15%, rgba(214, 174, 104, 0.18), transparent 52%),
			var(--gradient-dark-angled);
		color: var(--color-on-primary);
		box-shadow: var(--shadow-card);
		overflow: hidden;
	}

	.cta__panel::after {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: inherit;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
		pointer-events: none;
	}

	.cta__copy {
		display: grid;
		gap: 0.9rem;
	}

	.cta__copy .eyebrow {
		color: var(--color-secondary-strong);
	}

	h2,
	p {
		margin: 0;
	}

	h2 {
		font-family: var(--font-display);
		font-size: var(--text-h2);
		font-weight: 500;
		line-height: 1.04;
		letter-spacing: var(--tracking-tight);
		text-wrap: balance;
	}

	.cta__copy p {
		color: rgba(255, 255, 255, 0.74);
	}

	.cta__note {
		font-size: 0.9rem;
	}

	.cta__actions {
		display: grid;
		align-content: center;
		gap: 0.8rem;
	}

	@media (max-width: 860px) {
		.cta__panel {
			grid-template-columns: 1fr;
		}
	}
</style>
