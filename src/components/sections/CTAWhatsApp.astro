---
import Button from '../ui/Button.astro';
import Container from '../ui/Container.astro';
import { siteConfig } from '../../data/site';
---

<section class="cta section-shell">
	<Container>
		<div class="cta__panel">
			<div class="cta__copy">
				<span class="eyebrow">Canal de contacto</span>
				<h2>{siteConfig.cta.title}</h2>
				<p>{siteConfig.cta.description}</p>
				<p class="cta__note">{siteConfig.cta.note}</p>
			</div>

			<div class="cta__actions">
				<Button href={siteConfig.whatsappUrl} label={siteConfig.cta.primaryLabel} fullWidth target="_blank" rel="noopener noreferrer" />
				<Button href="/contacto" label={siteConfig.cta.secondaryLabel} variant="ghost" fullWidth />
			</div>
		</div>
	</Container>
</section>

<style>
	.cta {
		padding-top: 0;
	}

	.cta__panel {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.8fr);
		gap: var(--space-lg);
		padding: clamp(1.7rem, 4vw, 2.7rem);
		border-radius: var(--radius-xl);
		background:
			linear-gradient(135deg, rgba(8, 17, 35, 0.98) 0%, rgba(20, 39, 75, 0.96) 100%),
			var(--color-primary);
		color: var(--color-on-primary);
		box-shadow: var(--shadow-card);
	}

	.cta__copy {
		display: grid;
		gap: 0.9rem;
	}

	.cta__copy .eyebrow {
		color: var(--color-secondary-strong);
	}

	h2,
	p {
		margin: 0;
	}

	h2 {
		font-family: var(--font-display);
		font-size: clamp(2rem, 3.5vw, 3rem);
		line-height: 1.04;
	}

	.cta__copy p {
		color: rgba(255, 255, 255, 0.74);
	}

	.cta__note {
		font-size: 0.9rem;
	}

	.cta__actions {
		display: grid;
		align-content: center;
		gap: 0.8rem;
	}

	@media (max-width: 860px) {
		.cta__panel {
			grid-template-columns: 1fr;
		}
	}
</style>
