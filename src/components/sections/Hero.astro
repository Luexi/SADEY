---
import { Image } from 'astro:assets';
import Container from '../ui/Container.astro';
import { siteConfig } from '../../data/site';

const { hero } = siteConfig;
---

<section class="hero" id="inicio">
	<Container>
		<div class="hero__panel">
			<div class="hero__media">
				<Image
					src={hero.image.src}
					alt={hero.image.alt}
					widths={[960, 1600]}
					sizes="100vw"
					loading="eager"
					fetchpriority="high"
				/>
			</div>

			<div class="hero__overlay"></div>

			<div class="hero__content">
				<div class="hero__badge">
					<span class="badge__pulse"></span>
					{siteConfig.brandName}
				</div>
				<h1 class="hero__brand-question">
					¿A qué nos <br/><span class="text-gradient">dedicamos?</span>
				</h1>
				<p>{hero.description}</p>

				<ul class="hero__highlights" aria-label="Fortalezas destacadas">
					{hero.highlights.map((item) => <li>{item}</li>)}
				</ul>
			</div>
		</div>
	</Container>
</section>

<style>
	.hero {
		padding: 1.15rem 0 var(--space-lg);
	}

	.hero__panel {
		position: relative;
		min-height: clamp(32rem, 75vh, 40rem);
		overflow: hidden;
		border-radius: var(--radius-xl);
		background: var(--color-primary);
		box-shadow: var(--shadow-card);
		isolation: isolate;
	}

	.hero__panel::after {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: inherit;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), inset 0 0 0 1px rgba(255, 255, 255, 0.04);
		pointer-events: none;
		z-index: 2;
	}

	.hero__media,
	.hero__overlay {
		position: absolute;
		inset: 0;
	}

	.hero__media :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 35%;
	}

	.hero__overlay {
		background:
			radial-gradient(circle at 8% 92%, rgba(214, 174, 104, 0.26) 0%, rgba(8, 17, 35, 0) 48%),
			linear-gradient(90deg, rgba(8, 17, 35, 0.92) 0%, rgba(8, 17, 35, 0.8) 42%, rgba(8, 17, 35, 0.26) 100%),
			linear-gradient(180deg, rgba(8, 17, 35, 0.26) 0%, rgba(8, 17, 35, 0.74) 100%);
	}

	.hero__content {
		position: relative;
		z-index: 1;
		display: grid;
		gap: 1.2rem;
		max-width: 42rem;
		padding: clamp(2rem, 5vw, 4rem);
		color: var(--color-on-primary);
	}

	.hero__badge {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.35rem 1rem;
		width: max-content;
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 999px;
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.9);
		margin-bottom: 0.5rem;
		box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.1);
	}

	.badge__pulse {
		display: block;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background-color: var(--color-secondary-strong);
		box-shadow: 0 0 0 0 rgba(214, 174, 104, 0.7);
		animation: pulse 2s infinite cubic-bezier(0.66, 0, 0, 1);
	}

	@keyframes pulse {
		to {
			box-shadow: 0 0 0 10px rgba(214, 174, 104, 0);
		}
	}

	.hero__brand-question {
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 6.5vw, 4.5rem);
		font-weight: 800;
		line-height: 1.05;
		letter-spacing: -0.01em;
		margin: 0;
		color: var(--color-on-primary);
	}

	.text-gradient {
		background: linear-gradient(135deg, #ffffff 0%, var(--color-secondary-strong) 40%, rgba(214, 174, 104, 0.7) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		color: transparent;
		display: inline-block;
	}

	.hero__content p {
		margin: 0;
		max-width: 34rem;
		font-size: 1.02rem;
		color: rgba(255, 255, 255, 0.84);
	}

	.hero__highlights {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem 1.2rem;
		margin: 0;
		padding: 1rem 0 0;
		list-style: none;
	}

	.hero__highlights li {
		position: relative;
		padding-left: 1rem;
		font-size: 0.86rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		color: rgba(255, 255, 255, 0.76);
	}

	.hero__highlights li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.55rem;
		width: 0.4rem;
		height: 0.4rem;
		border-radius: 999px;
		background: var(--color-secondary-strong);
	}

	@media (max-width: 720px) {
		.hero__panel {
			min-height: auto;
		}

		.hero__overlay {
			background:
				linear-gradient(180deg, rgba(8, 17, 35, 0.82) 0%, rgba(8, 17, 35, 0.9) 58%, rgba(8, 17, 35, 0.92) 100%);
		}

		.hero__content {
			max-width: none;
			padding: 2rem 1.4rem;
		}

		.hero__badge {
			display: none;
		}
	}
</style>
