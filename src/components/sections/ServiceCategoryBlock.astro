---
import type { ServiceItem } from '../../data/types';
import { siteConfig } from '../../data/site';
import { withBase } from '../../utils/paths';
import PhotoCarousel from '../ui/PhotoCarousel.astro';

interface Props {
	service: ServiceItem;
}

const { service } = Astro.props;
const detailsLabel = service.detailsLabel ?? 'Pruebas especificas';
const hasCapas = Array.isArray(service.testsByCapa) && service.testsByCapa.length > 0;
const hasFutureDetails = Array.isArray(service.futureDetails) && service.futureDetails.length > 0;
const mediaVideo = service.media?.video;
const testGalleries = service.testGalleries ?? [];
const hasGalleries = testGalleries.length > 0;
const normalizeText = (value: string) =>
	value
		.normalize('NFD')
		.replace(/[\u0300-\u036f]/g, '')
		.toLowerCase()
		.replace(/[^a-z0-9]+/g, ' ')
		.trim();

const STOP_WORDS = new Set([
	'a',
	'al',
	'de',
	'del',
	'el',
	'en',
	'la',
	'las',
	'los',
	'para',
	'por',
	'y',
]);

const meaningfulTokens = (value: string) =>
	normalizeText(value)
		.split(' ')
		.filter((token) => token.length > 2 && !STOP_WORDS.has(token));

const tokenMatches = (token: string, candidates: string[]) =>
	candidates.some((candidate) => {
		if (candidate === token) return true;
		const shortest = Math.min(candidate.length, token.length);
		return shortest >= 5 && candidate.slice(0, 5) === token.slice(0, 5);
	});

const testMatchesGallery = (testName: string, gallery: (typeof testGalleries)[number]) => {
	const testNorm = normalizeText(testName);
	const titleNorm = normalizeText(gallery.testTitle);
	const slugNorm = normalizeText(gallery.testSlug.replaceAll('-', ' '));
	if (!testNorm || !titleNorm) return false;
	if (testNorm.includes(titleNorm) || titleNorm.includes(testNorm) || testNorm.includes(slugNorm)) {
		return true;
	}

	const testTokens = meaningfulTokens(testName);
	const galleryTokens = meaningfulTokens(`${gallery.testTitle} ${gallery.testSlug.replaceAll('-', ' ')}`);
	if (galleryTokens.length === 0) return false;

	const matches = galleryTokens.filter((token) => tokenMatches(token, testTokens)).length;
	const required = galleryTokens.length <= 2 ? galleryTokens.length : Math.ceil(galleryTokens.length * 0.6);
	return matches >= required;
};

const hasGalleryForTest = (testName: string) =>
	testGalleries.some((gallery) => testMatchesGallery(testName, gallery));

const uniqueByText = (items: string[]) => {
	const seen = new Set<string>();
	return items.filter((item) => {
		const key = normalizeText(item);
		if (seen.has(key)) return false;
		seen.add(key);
		return true;
	});
};

const futureDetailsWithoutGallery =
	hasFutureDetails ? service.futureDetails!.filter((detail) => !hasGalleryForTest(detail)) : [];

const capaTestsWithoutGallery = hasCapas
	? uniqueByText(
			service.testsByCapa!.flatMap((capa) => capa.tests).filter((test) => !hasGalleryForTest(test)),
		)
	: [];

const extraDetails = hasCapas ? capaTestsWithoutGallery : futureDetailsWithoutGallery;
const hasExtraDetails = extraDetails.length > 0;

const getAppliesForGallery = (gallery: (typeof testGalleries)[number]) => {
	if (!hasCapas) return [];
	const applies = service.testsByCapa!.flatMap((capa) => {
		const matches = capa.tests.some((test) => testMatchesGallery(test, gallery));
		if (!matches) return [];
		return capa.appliesTo && capa.appliesTo.length > 0 ? capa.appliesTo : [capa.capaTitle];
	});
	return uniqueByText(applies);
};

const isVideoGallery = (gallery: (typeof testGalleries)[number]) =>
	Boolean(mediaVideo) && normalizeText(`${gallery.testSlug} ${gallery.testTitle}`).includes('amaac');

const videoIsAttachedToGallery = mediaVideo && testGalleries.some((gallery) => isVideoGallery(gallery));
const visualSummary = mediaVideo
	? 'Fotos y video optimizados para consulta movil.'
	: 'Fotos optimizadas para consulta movil.';
---

<article class="service-category" id={service.slug}>
	<div class="service-category__header">
		<div class="service-category__icon">
			<span class="material-symbols-outlined" aria-hidden="true">
				{service.icon ?? 'construction'}
			</span>
		</div>
		<div class="service-category__intro">
			<h2>{service.title}</h2>
			<p>{service.shortDescription}</p>
		</div>
	</div>

	{hasGalleries && (
		<div class="service-category__tests">
			<div class="service-category__section-header">
				<h3 class="service-category__rubric">Pruebas con registro visual</h3>
				<p>{visualSummary}</p>
			</div>

			<div class="service-category__test-bubbles">
				{testGalleries.map((gallery, index) => {
					const applies = getAppliesForGallery(gallery);
					const attachVideo = isVideoGallery(gallery);
					return (
						<details
							class="service-category__test-bubble"
							id={`prueba-${service.slug}-${gallery.testSlug}`}
							open={index === 0}
						>
							<summary>
								<span class="service-category__bubble-title">{gallery.testTitle}</span>
								<span class="service-category__bubble-meta">
									<span>{gallery.images.length} {gallery.images.length === 1 ? 'foto' : 'fotos'}</span>
									{attachVideo && <span>video</span>}
									<span class="material-symbols-outlined service-category__bubble-chevron" aria-hidden="true">expand_more</span>
								</span>
							</summary>
							<div class="service-category__bubble-content">
								{applies.length > 0 && (
									<div class="service-category__applies-group">
										<span>Aplica a</span>
										<ul class="service-category__applies" aria-label={`Capas donde aplica ${gallery.testTitle}`}>
											{applies.map((item) => <li>{item}</li>)}
										</ul>
									</div>
								)}
								<PhotoCarousel
									id={`${service.slug}-${gallery.testSlug}`}
									label={`Fotos de ${gallery.testTitle}`}
									images={gallery.images}
								/>
								{attachVideo && mediaVideo && (
									<figure class="service-category__video-card">
										<video
											controls
											muted
											playsinline
											preload="metadata"
											poster={withBase(mediaVideo.poster, siteConfig.basePath)}
										>
											<source src={withBase(mediaVideo.src, siteConfig.basePath)} type="video/mp4" />
											Tu navegador no soporta video HTML5.
										</video>
										<figcaption>
											<strong>{mediaVideo.title}</strong>
											<span>{mediaVideo.description}</span>
										</figcaption>
									</figure>
								)}
							</div>
						</details>
					);
				})}
			</div>
		</div>
	)}

	{mediaVideo && !videoIsAttachedToGallery && (
		<div class="service-category__tests">
			<details class="service-category__test-bubble" open={!hasGalleries}>
				<summary>
					<span class="service-category__bubble-title">{mediaVideo.title}</span>
					<span class="service-category__bubble-meta">
						<span>video</span>
						<span class="material-symbols-outlined service-category__bubble-chevron" aria-hidden="true">expand_more</span>
					</span>
				</summary>
				<div class="service-category__bubble-content">
					<figure class="service-category__video-card">
						<video
							controls
							muted
							playsinline
							preload="metadata"
							poster={withBase(mediaVideo.poster, siteConfig.basePath)}
						>
							<source src={withBase(mediaVideo.src, siteConfig.basePath)} type="video/mp4" />
							Tu navegador no soporta video HTML5.
						</video>
						<figcaption>
							<strong>{mediaVideo.title}</strong>
							<span>{mediaVideo.description}</span>
						</figcaption>
					</figure>
				</div>
			</details>
		</div>
	)}

	{hasExtraDetails && (
		<div class="service-category__body">
			<details class="service-category__extra" open={!hasGalleries}>
				<summary>
					<span>{hasGalleries ? 'Otras pruebas sin registro visual' : detailsLabel}</span>
					<span class="service-category__extra-count">{extraDetails.length}</span>
					<span class="material-symbols-outlined service-category__bubble-chevron" aria-hidden="true">expand_more</span>
				</summary>
				<ul class={`service-category__details-list${extraDetails.length > 10 ? ' service-category__details-list--dense' : ''}`}>
					{extraDetails.map((detail) => <li>{detail}</li>)}
				</ul>
			</details>
		</div>
	)}
</article>

<style>
	.service-category {
		display: grid;
		gap: 1.5rem;
		padding: 2rem 1.75rem;
		background: var(--color-surface-strong);
		border: 1px solid transparent;
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-sm);
		transition:
			transform var(--transition-base),
			box-shadow var(--transition-base),
			border-color var(--transition-base);
	}

	.service-category:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-card);
		border-color: rgba(181, 135, 63, 0.2);
	}

	.service-category__header {
		display: flex;
		gap: 1.25rem;
		align-items: flex-start;
	}

	.service-category__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 3.4rem;
		height: 3.4rem;
		border-radius: 999px;
		background: var(--color-secondary-soft);
		color: var(--color-secondary);
	}

	.service-category__icon :global(.material-symbols-outlined) {
		font-size: 1.55rem;
	}

	.service-category__intro {
		display: grid;
		gap: 0.5rem;
	}

	.service-category__intro h2 {
		margin: 0;
		font-family: var(--font-display);
		font-size: 1.4rem;
		line-height: 1.1;
		color: var(--color-primary);
	}

	.service-category__intro p {
		margin: 0;
		color: var(--color-on-surface-variant);
	}

	.service-category__body,
	.service-category__tests {
		display: grid;
		gap: 1rem;
		padding-top: 0.5rem;
		border-top: 1px solid var(--color-line);
	}

	.service-category__rubric {
		margin: 0;
		font-family: var(--font-body);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--color-secondary);
	}

	.service-category__section-header p {
		margin: 0;
		font-size: 0.88rem;
		color: var(--color-on-surface-variant);
	}

	.service-category__section-header {
		display: grid;
		gap: 0.35rem;
	}

	.service-category__details-list {
		display: grid;
		gap: 0.6rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.service-category__details-list li {
		position: relative;
		padding-left: 1rem;
		font-size: 0.95rem;
		color: var(--color-on-surface-variant);
		transition: color var(--transition-base);
	}

	.service-category__details-list li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.68rem;
		width: 0.3rem;
		height: 0.3rem;
		border-radius: 999px;
		background: var(--color-secondary);
	}

	.service-category__details-list li:hover {
		color: var(--color-on-surface);
	}

	.service-category__details-list--dense {
		column-count: 2;
		column-gap: 1.75rem;
	}

	.service-category__details-list--dense li {
		break-inside: avoid;
		page-break-inside: avoid;
	}

	.service-category__test-bubbles {
		display: grid;
		gap: 0.5rem;
		margin-top: 0.5rem;
	}

	.service-category__test-bubble,
	.service-category__extra {
		border: 1px solid var(--color-line);
		border-radius: var(--radius-md, 0.6rem);
		background: var(--color-surface);
		overflow: hidden;
		transition: border-color var(--transition-base), box-shadow var(--transition-base);
	}

	.service-category__test-bubble[open],
	.service-category__extra[open] {
		border-color: rgba(181, 135, 63, 0.35);
		box-shadow: var(--shadow-sm);
	}

	.service-category__test-bubble:target {
		border-color: var(--color-secondary);
	}

	.service-category__test-bubble > summary,
	.service-category__extra > summary {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: center;
		gap: 0.75rem;
		padding: 0.85rem 1rem;
		list-style: none;
		cursor: pointer;
		font-weight: 600;
		color: var(--color-primary);
	}

	.service-category__test-bubble > summary::-webkit-details-marker,
	.service-category__extra > summary::-webkit-details-marker {
		display: none;
	}

	.service-category__test-bubble > summary:focus-visible,
	.service-category__extra > summary:focus-visible {
		outline: 2px solid var(--color-secondary);
		outline-offset: -4px;
	}

	.service-category__bubble-title {
		min-width: 0;
		font-family: var(--font-display);
		font-size: 0.98rem;
		line-height: 1.2;
		color: var(--color-primary);
	}

	.service-category__bubble-meta {
		display: inline-flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.45rem;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--color-on-surface-variant);
		white-space: nowrap;
	}

	.service-category__bubble-meta > span:not(.material-symbols-outlined),
	.service-category__extra-count {
		padding: 0.18rem 0.42rem;
		border-radius: 999px;
		background: var(--color-surface-strong);
		border: 1px solid rgba(181, 135, 63, 0.18);
	}

	.service-category__bubble-chevron {
		font-size: 1.3rem !important;
		color: var(--color-secondary);
		transition: transform var(--transition-base);
	}

	.service-category__test-bubble[open] .service-category__bubble-chevron,
	.service-category__extra[open] .service-category__bubble-chevron {
		transform: rotate(180deg);
	}

	.service-category__bubble-content {
		display: grid;
		gap: 0.8rem;
		padding: 0 0.75rem 0.85rem;
	}

	.service-category__applies {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin: 0 0 0.85rem;
		padding: 0;
		list-style: none;
	}

	.service-category__applies-group {
		display: grid;
		gap: 0.45rem;
		padding: 0.2rem 0.25rem 0;
	}

	.service-category__applies-group > span {
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--color-secondary);
	}

	.service-category__applies li {
		padding: 0.36rem 0.62rem;
		border-radius: 999px;
		background: var(--color-secondary-soft);
		font-size: 0.74rem;
		font-weight: 700;
		color: var(--color-secondary);
	}

	.service-category__video-card {
		margin: 0;
		overflow: hidden;
		border: 1px solid var(--color-line);
		border-radius: var(--radius-lg);
		background: var(--color-surface);
		box-shadow: var(--shadow-xs);
	}

	.service-category__video-card video {
		display: block;
		width: 100%;
		max-height: min(75vh, 42rem);
		background: var(--color-primary-deep);
	}

	.service-category__video-card figcaption {
		display: grid;
		gap: 0.25rem;
		padding: 0.9rem 1rem;
	}

	.service-category__video-card strong {
		font-family: var(--font-display);
		font-size: 0.96rem;
		color: var(--color-primary);
	}

	.service-category__video-card span {
		font-size: 0.86rem;
		color: var(--color-on-surface-variant);
	}

	.service-category__extra {
		background: var(--color-surface-strong);
	}

	.service-category__extra > summary {
		grid-template-columns: minmax(0, 1fr) auto auto;
	}

	.service-category__extra .service-category__details-list {
		padding: 0 1rem 1rem;
	}

	@media (min-width: 860px) {
		.service-category__test-bubble > summary,
		.service-category__extra > summary {
			padding-inline: 1.1rem;
		}
	}

	@media (max-width: 720px) {
		.service-category__details-list--dense {
			column-count: 1;
		}
	}

	@media (max-width: 560px) {
		.service-category {
			padding: 1.45rem 1.1rem;
		}

		.service-category__header {
			gap: 0.9rem;
		}

		.service-category__test-bubble > summary,
		.service-category__extra > summary {
			align-items: start;
			padding: 0.8rem 0.85rem;
		}

		.service-category__bubble-meta {
			gap: 0.35rem;
			font-size: 0.64rem;
		}

		.service-category__bubble-content {
			padding-inline: 0.55rem;
		}
	}
</style>
