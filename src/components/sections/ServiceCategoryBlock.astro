---
import type { ServiceItem } from '../../data/types';

interface Props {
	service: ServiceItem;
}

const { service } = Astro.props;
const detailsLabel = service.detailsLabel ?? 'Pruebas específicas';
const hasCapas = Array.isArray(service.testsByCapa) && service.testsByCapa.length > 0;
const hasFutureDetails = Array.isArray(service.futureDetails) && service.futureDetails.length > 0;
---

<article class="service-category" id={service.slug}>
	<div class="service-category__header">
		<div class="service-category__icon">
			<span class="material-symbols-outlined" aria-hidden="true">
				{service.icon ?? 'construction'}
			</span>
		</div>
		<div class="service-category__intro">
			<h2>{service.title}</h2>
			<p>{service.shortDescription}</p>
		</div>
	</div>

	{hasCapas && (
		<div class="service-category__body">
			<h3 class="service-category__rubric">{detailsLabel}</h3>
			<p class="service-category__hint">Selecciona una capa para ver las pruebas específicas que le corresponden.</p>

			<div class="service-category__capa-panels">
				{service.testsByCapa!.map((capa) => (
					<details class="service-category__capa" id={`capa-${capa.capaSlug}`}>
						<summary>
							<span class="service-category__capa-title">{capa.capaTitle}</span>
							<span class="material-symbols-outlined service-category__capa-chevron" aria-hidden="true">expand_more</span>
						</summary>
						<div class="service-category__capa-content">
							{capa.tests.length > 0 ? (
								<ul>
									{capa.tests.map((test) => <li>{test}</li>)}
								</ul>
							) : (
								<p class="service-category__capa-empty">Pruebas por confirmar.</p>
							)}
						</div>
					</details>
				))}
			</div>
		</div>
	)}

	{!hasCapas && hasFutureDetails && (
		<div class="service-category__body">
			<h3 class="service-category__rubric">{detailsLabel}</h3>
			<ul class={`service-category__details-list${service.futureDetails!.length > 10 ? ' service-category__details-list--dense' : ''}`}>
				{service.futureDetails!.map((detail) => <li>{detail}</li>)}
			</ul>
		</div>
	)}
</article>

{hasCapas && (
	<script is:inline>
		(() => {
			const openFromHash = () => {
				const hash = window.location.hash;
				if (!hash || !hash.startsWith('#capa-')) return;
				const target = document.querySelector(hash);
				if (target && target.tagName === 'DETAILS') {
					target.open = true;
					target.scrollIntoView({ behavior: 'smooth', block: 'start' });
				}
			};
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', openFromHash);
			} else {
				openFromHash();
			}
			window.addEventListener('hashchange', openFromHash);
		})();
	</script>
)}

<style>
	.service-category {
		display: grid;
		gap: 1.5rem;
		padding: 2rem 1.75rem;
		background: var(--color-surface-strong);
		border: 1px solid transparent;
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-sm);
		transition:
			transform var(--transition-base),
			box-shadow var(--transition-base),
			border-color var(--transition-base);
	}

	.service-category:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-card);
		border-color: rgba(181, 135, 63, 0.2);
	}

	.service-category__header {
		display: flex;
		gap: 1.25rem;
		align-items: flex-start;
	}

	.service-category__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 3.4rem;
		height: 3.4rem;
		border-radius: 999px;
		background: var(--color-secondary-soft);
		color: var(--color-secondary);
	}

	.service-category__icon :global(.material-symbols-outlined) {
		font-size: 1.55rem;
	}

	.service-category__intro {
		display: grid;
		gap: 0.5rem;
	}

	.service-category__intro h2 {
		margin: 0;
		font-family: var(--font-display);
		font-size: 1.4rem;
		line-height: 1.1;
		color: var(--color-primary);
	}

	.service-category__intro p {
		margin: 0;
		color: var(--color-on-surface-variant);
	}

	.service-category__body {
		display: grid;
		gap: 1rem;
		padding-top: 0.5rem;
		border-top: 1px solid var(--color-line);
	}

	.service-category__rubric {
		margin: 0;
		font-family: var(--font-body);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--color-secondary);
	}

	.service-category__hint {
		margin: 0;
		font-size: 0.88rem;
		color: var(--color-on-surface-variant);
	}

	.service-category__details-list {
		display: grid;
		gap: 0.6rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.service-category__details-list li {
		position: relative;
		padding-left: 1rem;
		font-size: 0.95rem;
		color: var(--color-on-surface-variant);
		transition: color var(--transition-base);
	}

	.service-category__details-list li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.68rem;
		width: 0.3rem;
		height: 0.3rem;
		border-radius: 999px;
		background: var(--color-secondary);
	}

	.service-category__details-list li:hover {
		color: var(--color-on-surface);
	}

	.service-category__details-list--dense {
		column-count: 2;
		column-gap: 1.75rem;
	}

	.service-category__details-list--dense li {
		break-inside: avoid;
		page-break-inside: avoid;
	}

	.service-category__capa-panels {
		display: grid;
		gap: 0.5rem;
		margin-top: 0.5rem;
	}

	.service-category__capa {
		border: 1px solid var(--color-line);
		border-radius: var(--radius-md, 0.6rem);
		background: var(--color-surface);
		overflow: hidden;
		transition: border-color var(--transition-base), box-shadow var(--transition-base);
	}

	.service-category__capa[open] {
		border-color: rgba(181, 135, 63, 0.35);
		box-shadow: var(--shadow-sm);
	}

	.service-category__capa:target {
		border-color: var(--color-secondary);
	}

	.service-category__capa > summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.85rem 1rem;
		list-style: none;
		cursor: pointer;
		font-weight: 600;
		color: var(--color-primary);
	}

	.service-category__capa > summary::-webkit-details-marker {
		display: none;
	}

	.service-category__capa-title {
		font-size: 0.98rem;
	}

	.service-category__capa-chevron {
		font-size: 1.3rem !important;
		color: var(--color-secondary);
		transition: transform var(--transition-base);
	}

	.service-category__capa[open] .service-category__capa-chevron {
		transform: rotate(180deg);
	}

	.service-category__capa-content {
		padding: 0 1rem 1rem;
	}

	.service-category__capa-content ul {
		display: grid;
		gap: 0.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.service-category__capa-content li {
		position: relative;
		padding-left: 1rem;
		font-size: 0.92rem;
		color: var(--color-on-surface-variant);
	}

	.service-category__capa-content li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.6rem;
		width: 0.3rem;
		height: 0.3rem;
		border-radius: 999px;
		background: var(--color-secondary);
	}

	.service-category__capa-empty {
		margin: 0;
		font-size: 0.9rem;
		color: var(--color-on-surface-variant);
		font-style: italic;
	}

	@media (max-width: 720px) {
		.service-category__details-list--dense {
			column-count: 1;
		}
	}
</style>
