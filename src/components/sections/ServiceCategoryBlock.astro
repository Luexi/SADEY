---
import type { ServiceItem } from '../../data/types';

interface Props {
	service: ServiceItem;
}

const { service } = Astro.props;
---

<article class="service-category" id={service.slug}>
	<div class="service-category__header">
		<div class="service-category__icon">
			<span class="material-symbols-outlined" aria-hidden="true">
				{service.icon ?? 'construction'}
			</span>
		</div>
		<div class="service-category__intro">
			<h2>{service.title}</h2>
			<p>{service.shortDescription}</p>
		</div>
	</div>

	<div class="service-category__details">
		<div class="service-category__column">
			<h3>Alcance</h3>
			<ul>
				{service.bullets.map((bullet) => <li>{bullet}</li>)}
			</ul>
		</div>

		{service.futureDetails && service.futureDetails.length > 0 && (
			<div class={`service-category__column service-category__column--wide${service.futureDetails.length > 10 ? ' service-category__column--dense' : ''}`}>
				<h3>Pruebas específicas</h3>
				<ul class="service-category__details-list">
					{service.futureDetails.map((detail) => <li>{detail}</li>)}
				</ul>
			</div>
		)}
	</div>
</article>

<style>
	.service-category {
		display: grid;
		gap: 1.5rem;
		padding: 2rem 1.75rem;
		background: var(--color-surface-strong);
		border: 1px solid transparent;
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-sm);
		transition:
			transform var(--transition-base),
			box-shadow var(--transition-base),
			border-color var(--transition-base);
	}

	.service-category:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-card);
		border-color: rgba(181, 135, 63, 0.2);
	}

	.service-category__header {
		display: flex;
		gap: 1.25rem;
		align-items: flex-start;
	}

	.service-category__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 3.4rem;
		height: 3.4rem;
		border-radius: 999px;
		background: var(--color-secondary-soft);
		color: var(--color-secondary);
	}

	.service-category__icon :global(.material-symbols-outlined) {
		font-size: 1.55rem;
	}

	.service-category__intro {
		display: grid;
		gap: 0.5rem;
	}

	.service-category__intro h2 {
		margin: 0;
		font-family: var(--font-display);
		font-size: 1.4rem;
		line-height: 1.1;
		color: var(--color-primary);
	}

	.service-category__intro p {
		margin: 0;
		color: var(--color-on-surface-variant);
	}

	.service-category__details {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 1.5rem;
		padding-top: 0.5rem;
		border-top: 1px solid var(--color-line);
	}

	.service-category__column h3 {
		margin: 0 0 0.75rem;
		font-family: var(--font-body);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--color-secondary);
	}

	li {
		transition: color var(--transition-base);
	}

	.service-category__details-list li:hover {
		color: var(--color-on-surface);
	}

	ul {
		display: grid;
		gap: 0.6rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	li {
		position: relative;
		padding-left: 1rem;
		font-size: 0.95rem;
		color: var(--color-on-surface-variant);
	}

	li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.68rem;
		width: 0.3rem;
		height: 0.3rem;
		border-radius: 999px;
		background: var(--color-secondary);
	}

	.service-category__column--wide {
		grid-column: 1 / -1;
	}

	.service-category__column--dense .service-category__details-list {
		column-count: 2;
		column-gap: 1.75rem;
	}

	.service-category__column--dense .service-category__details-list li {
		break-inside: avoid;
		page-break-inside: avoid;
	}

	@media (max-width: 720px) {
		.service-category__column--dense .service-category__details-list {
			column-count: 1;
		}
	}
</style>
