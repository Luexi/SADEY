---
import Card from '../ui/Card.astro';
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { services } from '../../data/services';
---

<section class="services section-shell" id="servicios">
	<Container>
		<SectionHeading
			eyebrow="Servicios principales"
			title="Base de servicios preparada para crecer sin perder orden"
			description="La landing presenta los servicios clave de SADEY y deja espacio para ampliar detalle técnico en futuras subpáginas o fichas especializadas."
		/>

		<div class="services__grid">
			{
				services.map((service) => (
					<Card className="services__card">
						<div class="services__card-head">
							<p class="services__slug">{service.slug}</p>
							<h3>{service.title}</h3>
						</div>
						<p class="services__summary">{service.shortDescription}</p>
						<ul>
							{service.bullets.map((bullet) => <li>{bullet}</li>)}
						</ul>
					</Card>
				))
			}
		</div>
	</Container>
</section>

<style>
	.services__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--space-md);
		margin-top: var(--space-xl);
	}

	.services__card {
		display: grid;
		gap: var(--space-sm);
	}

	.services__card-head {
		display: grid;
		gap: 0.25rem;
	}

	.services__slug {
		margin: 0;
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--color-accent-strong);
	}

	h3 {
		margin: 0;
		font-family: var(--font-display);
		font-size: 1.55rem;
	}

	.services__summary {
		margin: 0;
		color: var(--color-text-muted);
	}

	ul {
		margin: 0;
		padding-left: 1.1rem;
		color: var(--color-text-muted);
	}

	@media (max-width: 820px) {
		.services__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
