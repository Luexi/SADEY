---
import Button from '../ui/Button.astro';
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { services } from '../../data/services';

const serviceIcons: Record<string, string> = {
	concretos: 'science',
	'agregados-petreos': 'blur_on',
	'mezcla-asfaltica': 'local_shipping',
	suelos: 'foundation',
	siac: 'verified',
};
---

<section class="services section-shell" id="servicios">
	<Container>
		<SectionHeading
			eyebrow="Nuestros servicios"
			title="Pruebas específicas por categoría"
			description="Áreas en las que SADEY LABORATORIO ejecuta pruebas específicas y brinda apoyo técnico a proyectos de construcción y a laboratorios externos."
			align="center"
		/>

		<div class="services__grid">
			{
				services.map((service) => (
					<article class="services__card">
						<div class="services__icon">
							<span class="material-symbols-outlined" aria-hidden="true">
								{serviceIcons[service.slug] ?? service.icon ?? 'construction'}
							</span>
						</div>
						<h3>{service.title}</h3>
						<p class="services__summary">{service.shortDescription}</p>
					</article>
				))
			}
		</div>

		<div class="services__actions">
			<Button href="/servicios" label="Ver todos los servicios" variant="secondary" />
		</div>
	</Container>
</section>

<style>
	.services {
		background: var(--color-surface);
	}

	.services__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.25rem;
		margin-top: var(--space-xl);
	}

	.services__card {
		display: grid;
		gap: 0.75rem;
		padding: 1.5rem 1.35rem;
		background: var(--color-surface-strong);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-soft);
	}

	.services__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		border-radius: 999px;
		background: var(--color-secondary-soft);
		color: var(--color-secondary);
	}

	.services__icon :global(.material-symbols-outlined) {
		font-size: 1.4rem;
	}

	h3,
	.services__summary {
		margin: 0;
	}

	h3 {
		font-family: var(--font-display);
		font-size: 1.15rem;
		line-height: 1.1;
		color: var(--color-primary);
	}

	.services__summary {
		color: var(--color-on-surface-variant);
		font-size: 0.92rem;
	}

	.services__actions {
		display: flex;
		justify-content: center;
		margin-top: var(--space-lg);
	}

	@media (max-width: 640px) {
		.services__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
