---
import Button from '../ui/Button.astro';
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { services } from '../../data/services';

const featuredServiceOrder = ['concretos', 'agregados-petreos', 'suelos'];
const featuredServices = featuredServiceOrder
	.map((slug) => services.find((service) => service.slug === slug))
	.filter((service): service is (typeof services)[number] => Boolean(service));

const serviceIcons: Record<string, string> = {
	concretos: 'science',
	'agregados-petreos': 'blur_on',
	suelos: 'foundation',
};
---

<section class="services section-shell" id="servicios">
	<Container>
		<SectionHeading
			eyebrow="Especialidades técnicas"
			title="Servicios enfocados en control de calidad, ensaye y apoyo técnico en proyecto"
			description="SADEY presenta en esta vista las tres capacidades principales que mejor representan su trabajo operativo y técnico."
			align="center"
		/>

		<div class="services__grid">
			{
				featuredServices.map((service) => (
					<article class="services__card">
						<div class="services__icon">
							<span class="material-symbols-outlined" aria-hidden="true">
								{serviceIcons[service.slug] ?? 'construction'}
							</span>
						</div>
						<h3>{service.title}</h3>
						<p class="services__summary">{service.shortDescription}</p>
						<ul>
							{service.bullets.map((bullet) => <li>{bullet}</li>)}
						</ul>
					</article>
				))
			}
		</div>

		<div class="services__actions">
			<Button href="#proyectos" label="Ver proyectos recientes" variant="secondary" />
		</div>
	</Container>
</section>

<style>
	.services {
		background: var(--color-surface);
	}

	.services__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.25rem;
		margin-top: var(--space-xl);
	}

	.services__card {
		display: grid;
		gap: 0.9rem;
		padding: 2rem 1.75rem;
		background: var(--color-surface-strong);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-soft);
	}

	.services__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.4rem;
		height: 3.4rem;
		border-radius: 999px;
		background: var(--color-secondary-soft);
		color: var(--color-secondary);
	}

	.services__icon :global(.material-symbols-outlined) {
		font-size: 1.55rem;
	}

	h3,
	.services__summary {
		margin: 0;
	}

	h3 {
		font-family: var(--font-display);
		font-size: 1.34rem;
		line-height: 1.08;
		color: var(--color-primary);
	}

	.services__summary,
	li {
		color: var(--color-on-surface-variant);
	}

	ul {
		display: grid;
		gap: 0.7rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	li {
		position: relative;
		padding-left: 1rem;
		font-size: 0.95rem;
	}

	li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.68rem;
		width: 0.35rem;
		height: 0.35rem;
		border-radius: 999px;
		background: var(--color-secondary);
	}

	.services__actions {
		display: flex;
		justify-content: center;
		margin-top: var(--space-lg);
	}

	@media (max-width: 980px) {
		.services__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
