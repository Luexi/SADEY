---
import { siteConfig } from '../../data/site';

const { mapQuery } = siteConfig.contact;
const mapSrc = `https://www.google.com/maps?q=${mapQuery}&output=embed`;
---

<div class="map-block">
	<iframe
		src={mapSrc}
		title="Ubicación de MTHA SADEY en el mapa"
		width="100%"
		height="380"
		style="border:0;"
		allowfullscreen=""
		loading="lazy"
		referrerpolicy="no-referrer-when-downgrade"
	></iframe>
</div>

<style>
	.map-block {
		border-radius: var(--radius-lg);
		overflow: hidden;
		box-shadow: var(--shadow-soft);
	}

	iframe {
		display: block;
		width: 100%;
	}
</style>
